---
import banners from '../../banners.config';
import { Image } from 'astro:assets';
---

<div class="not-prose grid grid-cols-2 gap-2">
    {banners.map((banner) => (
        <a href={banner.href} rel="noopener noreferer" target="_blank">
            <Image src={banner.src} alt={banner.alt} />
        </a>
    ))}
</div>
