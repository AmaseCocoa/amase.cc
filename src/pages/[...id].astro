---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: { id: page.id === "index" ? undefined : page.id },
    props: { page },
  }));
}

const { page } = Astro.props;

const { Content } = await render(page);
---

<Layout>
  <div class="flex-1 pt-2 sm:pt-0 text-center sm:text-left">
    <div
      class="prose prose-sm max-w-none prose-slate prose-headings:text-gray-800 prose-p:text-gray-600 prose-a:text-blue-600 hover:prose-a:underline"
    >
      <Content />
    </div>
  </div>
</Layout>
