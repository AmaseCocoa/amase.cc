---
import Link from "../components/prose/Link.astro";
import SEO from "../components/SEO.astro";
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: { id: page.id === "index" ? undefined : page.id },
    props: { page },
  }));
}

const { page } = Astro.props;

const { Content } = await render(page);
---

<Layout>
  <SEO
    slot="seo"
    title={page.data.title}
    description={page.data.description}
  />

  <div class="flex-1 pt-2 sm:pt-0 text-center sm:text-left">
    <div
      class="content"
    >
      <Content components={{
        a: Link
      }} />
    </div>
  </div>
</Layout>

<style is:global>
  @reference "../styles/global.css";

  .content {
    @apply prose prose-sm max-w-none prose-slate prose-headings:text-gray-800 prose-p:text-gray-600 prose-a:text-blue-600 hover:prose-a:underline;
  }
</style>
